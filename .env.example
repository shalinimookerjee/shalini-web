# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — your key never gets committed.

# TMDB API key — used only by `npm run movies` to fetch posters + directors.
# Get a free one at https://www.themoviedb.org/settings/api (request an "API Key (v3 auth)").
TMDB_API_KEY=
